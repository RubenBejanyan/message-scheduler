# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# ── Telegram User Account (Telethon) ────────────────────────────────────────
# Get from https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION_PATH=./user_session

# ── AI Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.1-8b-instant
# Leave empty for OpenAI. Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: use 127.0.0.1 (not localhost — IPv6 resolution conflict on Windows)
# Docker: use the service name, e.g. postgresql+asyncpg://user:password@postgres:5432/dev_db
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/dev_db

# ── App ──────────────────────────────────────────────────────────────────────
MIN_INTERVAL_MINUTES=5
