# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# ── AI provider ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # leave empty for default OpenAI endpoint

# ── Database ──────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in infra .env
DATABASE_URL=postgresql+asyncpg://msched:CHANGE_ME@global_db:5432/message_scheduler

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://global_redis:6379/0

# ── App limits ────────────────────────────────────────────────────────────────
MIN_INTERVAL_MINUTES=5
MAX_SCHEDULES_PER_USER=10
